# Environment Variables Template
# 复制此文件为 .env.local 并填入实际的值

# Supabase 云端数据库
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# DeepSeek AI（慧慧AI助手）
DEEPSEEK_API_KEY=your-deepseek-api-key

# 博查联网搜索（可选，不配置则跳过联网搜索）
# 注册地址：https://open.bochaai.com
BOCHA_API_KEY=your-bocha-api-key

# 天眼查 Open API（已开通：搜索/对外投资/融资历史/投资事件/历史股东信息/企业基本信息）
# 控制台：https://open.tianyancha.com/console/mydata
TIANYANCHA_TOKEN=your-tianyancha-token

# 天眼查代理地址（仅在 Vercel 等海外服务器部署时需要配置）
# 天眼查封锁了海外 IP，需要在国内服务器上搭建 Nginx 反向代理
# 代理配置示例见下方说明，配置后填入代理域名，例如：
# TIANYANCHA_PROXY_BASE=https://tyc-proxy.your-domain.com
TIANYANCHA_PROXY_BASE=
