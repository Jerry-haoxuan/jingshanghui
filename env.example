# Environment Variables Template
# 复制此文件为 .env.local 并填入实际的值

# 阿里云 RDS PostgreSQL 数据库
# 本地开发使用外网地址，ECS 部署使用内网地址
DATABASE_URL=postgresql://用户名:密码@RDS地址:5432/ecosystem

# DeepSeek AI（慧慧AI助手）
DEEPSEEK_API_KEY=your-deepseek-api-key

# 博查联网搜索（可选，不配置则跳过联网搜索）
BOCHA_API_KEY=your-bocha-api-key

# 天眼查 Open API（国内服务器直连，无需代理）
TIANYANCHA_TOKEN=your-tianyancha-token

# 天眼查代理（仅海外服务器部署时需要，阿里云ECS无需配置）
TIANYANCHA_PROXY_BASE=
